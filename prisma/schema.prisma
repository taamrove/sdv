generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

// ============================================================
// AUTH DOMAIN — lives in "auth" schema, survives app DB resets
// ============================================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  firstName    String
  lastName     String
  phone        String?
  image        String?
  passwordHash String
  roleId       String
  contactId    String?   @unique
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role                Role               @relation(fields: [roleId], references: [id])
  // contactId links to public.Contact — Prisma relation intentionally omitted
  // (cross-schema auth→public FK breaks Prisma query engine in Next.js; use raw lookup when needed)
  maintenanceAssigned MaintenanceTicket[] @relation("AssignedTo")
  maintenanceReported MaintenanceTicket[] @relation("ReportedBy")
  maintenanceComments MaintenanceComment[]
  maintenancePhotos   MaintenancePhoto[]
  itemHistories       ItemHistory[]
  containerPackedBy   ContainerItem[]     @relation("PackedBy")
  containerVerifiedBy ContainerItem[]     @relation("VerifiedBy")
  betaFlags           FeatureFlagUser[]
  feedbackSubmitted   FeedbackTicket[]

  @@schema("auth")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@schema("auth")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
  @@schema("auth")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@schema("auth")
}

// ============================================================
// FEATURE FLAGS
// ============================================================

enum FeatureFlagStage {
  DEVELOPMENT
  ALPHA
  BETA
  PRODUCTION

  @@schema("public")
}

model FeatureFlag {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  stage       FeatureFlagStage @default(DEVELOPMENT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  betaUsers FeatureFlagUser[]

  @@schema("public")
}

model FeatureFlagUser {
  flagId String
  userId String

  flag FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([flagId, userId])
  @@schema("public")
}

// ============================================================
// PRODUCT DOMAIN
// ============================================================

model Category {
  id          String   @id @default(uuid())
  code        String   @unique @db.Char(1)
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products           Product[]
  items              Item[]
  subCategories      SubCategory[]
  quarantineDefaults CategoryQuarantineDefault[]

  @@schema("public")
}

/// SubCategory = admin-managed sub-type within a category (e.g. "Jacket" under "Costume").
/// sizeMode drives which size fields appear on Items: "clothing" | "shoes" | "hat" | "measurements"
model SubCategory {
  id         String   @id @default(uuid())
  categoryId String
  name       String
  sizeMode   String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@schema("public")
}

/// Product = a design/type (e.g. "Angel Shoe"). The template for physical Items.
model Product {
  id                    String   @id @default(uuid())
  categoryId            String
  subCategoryId         String?
  number                Int
  name                  String
  description           String?
  imageUrl              String?
  allowsSizeFlexibility Boolean  @default(true)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category           Category           @relation(fields: [categoryId], references: [id])
  subCategory        SubCategory?       @relation(fields: [subCategoryId], references: [id])
  items              Item[]
  kitVariantProducts KitVariantProduct[]
  packs              Pack[]

  @@unique([categoryId, number])
  @@schema("public")
}

/// Item = an individual physical copy (e.g. "Angel Shoe size 38", barcode S-001-003).
model Item {
  id                  String        @id @default(uuid())
  categoryId          String
  productId           String
  sequence            Int
  humanReadableId     String        @unique
  status              ItemStatus    @default(AVAILABLE)
  condition           ItemCondition @default(NEW)
  sizes               Json?
  color               String?
  purchaseDate        DateTime?
  purchasePrice       Decimal?      @db.Decimal(10, 2)
  notes               String?
  warehouseLocationId String?
  imageUrl            String?
  isExternal          Boolean       @default(false)
  archived            Boolean       @default(false)
  mainPerformerId     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  category           Category           @relation(fields: [categoryId], references: [id])
  product            Product            @relation(fields: [productId], references: [id])
  warehouseLocation  WarehouseLocation? @relation(fields: [warehouseLocationId], references: [id])
  mainPerformer      Performer?         @relation("ItemMainPerformer", fields: [mainPerformerId], references: [id])
  bookingItems       BookingItem[]
  containerItems     ContainerItem[]
  maintenanceTickets MaintenanceTicket[]
  history            ItemHistory[]
  packItems          PackItem[]

  @@unique([productId, sequence])
  @@index([status])
  @@index([humanReadableId])
  @@schema("public")
}

enum ItemStatus {
  AVAILABLE
  ASSIGNED
  PACKED
  IN_USE
  MAINTENANCE
  RETIRED
  LOST

  @@schema("public")
}

enum ItemCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR

  @@schema("public")
}

// ============================================================
// KIT DOMAIN (kits / compositions)
// ============================================================

/// Kit = a kit/set (e.g. "Angel Costume") composed of multiple Products.
model Kit {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants KitVariant[]
  themes   KitTheme[]
  bookings ProjectBooking[]

  @@schema("public")
}

/// KitVariant = a version of a kit (e.g. "Angel Costume — Blue").
model KitVariant {
  id          String   @id @default(uuid())
  kitId       String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kit      Kit                @relation(fields: [kitId], references: [id], onDelete: Cascade)
  products KitVariantProduct[]
  bookings ProjectBooking[]

  @@schema("public")
}

/// KitVariantProduct = which Products (and how many) compose a variant.
model KitVariantProduct {
  id        String  @id @default(uuid())
  variantId String
  productId String
  quantity  Int     @default(1)
  required  Boolean @default(true)
  notes     String?

  variant KitVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@unique([variantId, productId])
  @@schema("public")
}

/// KitTheme = many-to-many join between Kit and Theme.
model KitTheme {
  kitId   String
  themeId String

  kit   Kit   @relation(fields: [kitId], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([kitId, themeId])
  @@schema("public")
}

// ============================================================
// PACK DOMAIN
// ============================================================

model Pack {
  id              String        @id @default(uuid())
  productId       String
  humanReadableId String        @unique
  name            String?
  status          ItemStatus    @default(AVAILABLE)
  condition       ItemCondition @default(NEW)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  product   Product    @relation(fields: [productId], references: [id])
  packItems PackItem[]

  @@schema("public")
}

model PackItem {
  id     String @id @default(uuid())
  packId String
  itemId String

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@unique([packId, itemId])
  @@schema("public")
}

// ============================================================
// WAREHOUSE DOMAIN
// ============================================================

model WarehouseLocation {
  id          String   @id @default(uuid())
  zone        String
  rack        String?
  shelf       String?
  bin         String?
  label       String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items Item[]

  @@schema("public")
}

// ============================================================
// CONTACT HUB — single source of truth for any person
// ============================================================

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  performer  Performer?
  // user back-relation omitted — see User.contactId comment above
  addresses  ContactAddress[]
  companies  ContactCompany[]

  @@schema("public")
}

model Address {
  id        String   @id @default(uuid())
  line1     String?
  line2     String?
  city      String?
  postCode  String?
  country   String?
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts  ContactAddress[]
  companies CompanyAddress[]

  @@schema("public")
}

model ContactAddress {
  contactId String
  addressId String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@id([contactId, addressId])
  @@schema("public")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  vatNo     String?
  website   String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses CompanyAddress[]
  contacts  ContactCompany[]

  @@schema("public")
}

model CompanyAddress {
  companyId String
  addressId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@id([companyId, addressId])
  @@schema("public")
}

model ContactCompany {
  contactId String
  companyId String
  role      String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([contactId, companyId])
  @@schema("public")
}

// ============================================================
// PERFORMER DOMAIN
// ============================================================

model Performer {
  id                String        @id @default(uuid())
  contactId         String        @unique
  type              PerformerType @default(DANCER)
  sizes             Json?
  notes             String?
  externalId        String?       @unique
  active            Boolean       @default(true)
  requiresExactSize Boolean       @default(false)
  sizeFlexDirection String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  contact      Contact               @relation(fields: [contactId], references: [id])
  assignments  PerformerAssignment[]
  primaryItems Item[]                @relation("ItemMainPerformer")

  @@schema("public")
}

enum PerformerType {
  DANCER
  VOCALIST
  MUSICIAN
  ACROBAT
  ACTOR
  OTHER

  @@schema("public")
}

// ============================================================
// THEME DOMAIN
// ============================================================

/// Theme = a branding tag for Kits (many-to-many).
model Theme {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kits KitTheme[]

  @@schema("public")
}

// ============================================================
// PROJECT DOMAIN
// ============================================================

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  venue       String?
  city        String?
  country     String?
  startDate   DateTime?
  endDate     DateTime?
  status      ProjectStatus @default(PLANNING)
  externalId  String?       @unique
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assignments PerformerAssignment[]
  bookings    ProjectBooking[]
  containers  Container[]

  @@index([status])
  @@index([startDate])
  @@schema("public")
}

enum ProjectStatus {
  PLANNING
  CONFIRMED
  PACKING
  IN_TRANSIT
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("public")
}

model PerformerAssignment {
  id          String   @id @default(uuid())
  performerId String
  projectId   String
  role        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  performer    Performer              @relation(fields: [performerId], references: [id])
  project      Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookingNotes PerformerBookingNote[]

  @@unique([performerId, projectId])
  @@schema("public")
}

// ============================================================
// BOOKING DOMAIN
// ============================================================

enum BookingStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED

  @@schema("public")
}

/// ProjectBooking = "Book 6 Angel Costumes for Project X".
model ProjectBooking {
  id            String        @id @default(uuid())
  projectId     String
  kitId         String
  kitVariantId  String?
  quantity      Int           @default(1)
  status        BookingStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kit            Kit                  @relation(fields: [kitId], references: [id])
  variant        KitVariant?          @relation(fields: [kitVariantId], references: [id])
  items          BookingItem[]
  performerNotes PerformerBookingNote[]

  @@schema("public")
}

/// BookingItem = a concrete Item assigned to fulfill a booking.
model BookingItem {
  id         String   @id @default(uuid())
  bookingId  String
  itemId     String
  assignedAt DateTime @default(now())
  notes      String?

  booking ProjectBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item    Item           @relation(fields: [itemId], references: [id])

  @@unique([bookingId, itemId])
  @@schema("public")
}

/// PerformerBookingNote = notes about a performer's specific booking needs.
model PerformerBookingNote {
  id                    String   @id @default(uuid())
  performerAssignmentId String
  bookingId             String?
  notes                 String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  performerAssignment PerformerAssignment @relation(fields: [performerAssignmentId], references: [id], onDelete: Cascade)
  booking             ProjectBooking?     @relation(fields: [bookingId], references: [id])

  @@schema("public")
}

// ============================================================
// CONTAINER / PACKING DOMAIN
// ============================================================

model Container {
  id          String          @id @default(uuid())
  name        String
  type        ContainerType   @default(SUITCASE)
  description String?
  projectId   String?
  status      ContainerStatus @default(EMPTY)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project?       @relation(fields: [projectId], references: [id])
  items   ContainerItem[]

  @@schema("public")
}

enum ContainerType {
  SUITCASE
  BAG
  BOX
  GARMENT_BAG
  SHOE_BOX
  HAT_BOX
  CUSTOM

  @@schema("public")
}

enum ContainerStatus {
  EMPTY
  PACKING
  PACKED
  IN_TRANSIT
  AT_VENUE
  RETURNED
  UNPACKED

  @@schema("public")
}

model ContainerItem {
  id           String    @id @default(uuid())
  containerId  String
  itemId       String
  packedAt     DateTime  @default(now())
  packedById   String?
  verifiedAt   DateTime?
  verifiedById String?

  container  Container @relation(fields: [containerId], references: [id], onDelete: Cascade)
  item       Item      @relation(fields: [itemId], references: [id])
  packedBy   User?     @relation("PackedBy", fields: [packedById], references: [id])
  verifiedBy User?     @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@unique([containerId, itemId])
  @@schema("public")
}

// ============================================================
// MAINTENANCE DOMAIN
// ============================================================

model MaintenanceTicket {
  id                  String               @id @default(uuid())
  itemId              String
  reportedById        String
  assignedToId        String?
  status              MaintenanceStatus    @default(REPORTED)
  priority            MaintenancePriority  @default(MEDIUM)
  severity            MaintenanceSeverity?
  title               String
  description         String?
  estimatedCompletion DateTime?
  completedAt         DateTime?
  quarantineEndsAt    DateTime?
  quarantineType      QuarantineType       @default(NONE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  item       Item                 @relation(fields: [itemId], references: [id])
  reportedBy User                 @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedTo User?                @relation("AssignedTo", fields: [assignedToId], references: [id])
  photos     MaintenancePhoto[]
  comments   MaintenanceComment[]

  @@index([status])
  @@index([itemId])
  @@schema("public")
}

model CategoryQuarantineDefault {
  id                    String              @id @default(uuid())
  categoryId            String
  severity              MaintenanceSeverity
  defaultQuarantineDays Int
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, severity])
  @@schema("public")
}

enum MaintenanceStatus {
  REPORTED
  ASSESSED
  IN_PROGRESS
  AWAITING_PARTS
  COMPLETED
  CANCELLED

  @@schema("public")
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@schema("public")
}

enum MaintenanceSeverity {
  MINOR
  MODERATE
  UNUSABLE

  @@schema("public")
}

enum QuarantineType {
  NONE
  AUTO
  MANUAL

  @@schema("public")
}

model MaintenancePhoto {
  id           String   @id @default(uuid())
  ticketId     String
  url          String
  caption      String?
  uploadedById String
  createdAt    DateTime @default(now())

  ticket     MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation(fields: [uploadedById], references: [id])

  @@schema("public")
}

model MaintenanceComment {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id])

  @@schema("public")
}

// ============================================================
// AUDIT / HISTORY DOMAIN
// ============================================================

model ItemHistory {
  id            String        @id @default(uuid())
  itemId        String
  action        HistoryAction
  performedById String?
  details       Json?
  previousState Json?
  newState      Json?
  createdAt     DateTime      @default(now())

  item        Item  @relation(fields: [itemId], references: [id])
  performedBy User? @relation(fields: [performedById], references: [id])

  @@index([itemId, createdAt])
  @@index([action])
  @@schema("public")
}

enum HistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED_TO_BOOKING
  REMOVED_FROM_BOOKING
  PACKED
  UNPACKED
  CHECKED_OUT
  CHECKED_IN
  CHECKED_IN_TO_INVENTORY
  SENT_TO_MAINTENANCE
  LOCATION_CHANGED
  MAINTENANCE_STARTED
  MAINTENANCE_COMPLETED
  CONDITION_CHANGED
  QUARANTINE_STARTED
  QUARANTINE_ENDED
  RETIRED
  LOST
  FOUND
  CROSSLOADED

  @@schema("public")
}

// ============================================================
// FEEDBACK DOMAIN
// ============================================================

model FeedbackTicket {
  id            String           @id @default(uuid())
  title         String
  description   String?
  category      FeedbackCategory
  status        FeedbackStatus   @default(OPEN)
  priority      FeedbackPriority @default(MEDIUM)
  submittedById String
  resolvedAt    DateTime?
  devNotes      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  submittedBy User @relation(fields: [submittedById], references: [id])

  @@index([status])
  @@index([submittedById])
  @@schema("public")
}

enum FeedbackCategory {
  BUG
  FEATURE_REQUEST
  IMPROVEMENT

  @@schema("public")
}

enum FeedbackStatus {
  OPEN
  IN_REVIEW
  PLANNED
  RESOLVED
  CLOSED

  @@schema("public")
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH

  @@schema("public")
}

// ============================================================
// CHANGELOG DOMAIN
// ============================================================

model ChangelogEntry {
  id        String   @id @default(uuid())
  version   String
  title     String
  changes   String   // Markdown content
  buildId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}
