DATABASE_URL="postgresql://your_user@localhost:5432/sdv_lager"
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob storage (required for image uploads on Vercel)
# Create a blob store in your Vercel project settings and add the token here
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# For Docker setup (alternative), change port to 5433 to avoid conflicts:
# DATABASE_URL="postgresql://sdv:sdv_dev_password@localhost:5433/sdv_lager"
